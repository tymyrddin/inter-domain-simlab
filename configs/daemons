# FRR daemons file, shared by every router in the lab.
#
# This is a pure BGP fabric: bgpd carries the inter-domain routes, zebra
# programs them into the kernel, staticd serves the connected/loopback routes
# the `network` statements advertise. OSPF and the rest stay off; there is no
# intra-AS IGP to model in milestone 1.

bgpd=yes
ospfd=no
ospf6d=no
ripd=no
ripngd=no
isisd=no
pimd=no
pim6d=no
ldpd=no
nhrpd=no
eigrpd=no
babeld=no
sharpd=no
pbrd=no
bfdd=no
fabricd=no
vrrpd=no
pathd=no
zebra=yes
staticd=yes

# Common option overrides. Each daemon-specific *_options line is honoured
# when that daemon is yes.
zebra_options="  -A 127.0.0.1 -s 90000000"
staticd_options="-A 127.0.0.1"
# -M rpki loads the RPKI/RTR module (bgpd_rpki.so) so the transits can hold an RTR
# session and validate origins (section 17). -M bmp loads bgpd_bmp.so so the
# observer can stream its RIB to the bmp-collector (section 18, M4 increment 2).
# Both modules are in the FRR 9.1 image and are harmless where no matching config
# block exists, so the shared daemons file loads them on every router.
bgpd_options="  -A 127.0.0.1 -M rpki -M bmp"