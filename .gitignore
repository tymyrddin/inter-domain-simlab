# Python environments and caches
.venv/
__pycache__/
.pytest_cache/
.coverage
htmlcov/

# Editors and IDEs
.idea/
*.swp

# containerlab runtime state: one directory per deployed topology, recreated by ./ctl up
clab/clab-*/

# Per-deploy access credentials, generated by ./ctl up and ./ctl cohort-keys.
# Never commit: the committed image carries no working credential by design.
lab-key
lab-key.pub
cohort-key
cohort-key.pub
access/

# Bulky raw seed data pulled at setup time. Commit known-good run artefacts
# (a trimmed MRT plus the JSON timeline) deliberately instead of whole dumps.
seeds/mrt/*.bz2
seeds/mrt/*.gz
seeds/mrt/*.mrt
# but do commit the small, representative seed sample (the file the topology
# binds, so a fresh clone deploys offline). Raw dumps above stay ignored.
!seeds/mrt/seed.sample.mrt